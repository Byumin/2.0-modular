inpsyt-norm.com, www.inpsyt-norm.com {
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	@scan_paths {
		path /wp-admin* /wp-login.php /xmlrpc.php /wp-content* /wp-includes* /wordpress*
		path /*.php /.env* /.git* /composer.* /vendor/phpunit* /server-status /actuator*
	}
	handle @scan_paths {
		respond 404
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:8120
	}

	handle /static/* {
		reverse_proxy 127.0.0.1:8120
	}

	handle /artifacts/* {
		reverse_proxy 127.0.0.1:8120
	}

	handle /health {
		reverse_proxy 127.0.0.1:8120
	}

	handle {
		reverse_proxy 127.0.0.1:8120
	}
}
